<Window x:Class="Lab7.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:Lab7"
        mc:Ignorable="d"
        Title="Moje okno" Height="450" Width="800">
    <Grid>
        <Button x:Name="btnOk" Content="Display" HorizontalAlignment="Center" Margin="0,244,0,0" VerticalAlignment="Top" Height="27" Width="116" Click="btnOk_Click"/>
        <TextBlock HorizontalAlignment="Center" Margin="0,119,0,0" TextWrapping="Wrap" Text="Select a message option and then choose the Display button" VerticalAlignment="Top" FontSize ="16" FontWeight="Bold"/>
        <RadioButton x:Name="HelloButton" Content="Hello" HorizontalAlignment="Left" Margin="333,182,0,0" VerticalAlignment="Top" IsChecked="True"/>
        <RadioButton x:Name="GoodbyeButton" Content="Goodbye" HorizontalAlignment="Left" Margin="400,182,0,0" VerticalAlignment="Top" RenderTransformOrigin="-2.461,-0.532"/>

    </Grid>
</Window>
