<Window x:Class="Lab1.Views.MainForm"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:Lab1.Views"
        mc:Ignorable="d"
        Title="MainForm"
        WindowStartupLocation="CenterScreen"
        Background="#FFF5F7FB" WindowState="Maximized">

    <Window.Resources>

        <!-- SUBMENU BUTTON STYLE -->
        <Style x:Key="SubMenuButtonStyle" TargetType="Button">
            <Setter Property="Height" Value="38"/>
            <Setter Property="Margin" Value="10,4,10,4"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="Background" Value="#FF0058CC"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="FontSize" Value="15"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="HorizontalContentAlignment" Value="Left"/>
            <Setter Property="Padding" Value="15,0,0,0"/>
        </Style>

        <!-- EXPANDER STYLE -->
        <Style x:Key="MenuExpanderStyle" TargetType="Expander">
            <Setter Property="Margin" Value="10,6,10,6"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="IsExpanded" Value="False"/>
        </Style>

    </Window.Resources>

    <Grid>

        <!-- TWO COLUMNS -->
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="26"/>
            <ColumnDefinition Width="234"/>
            <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>

        <!-- LEFT MENU -->
        <Border Grid.Column="0"
                Background="#FF0047A1"
                CornerRadius="0,18,18,0" Grid.ColumnSpan="2">

            <ScrollViewer VerticalScrollBarVisibility="Auto"
                          HorizontalScrollBarVisibility="Disabled">

                <StackPanel Margin="0,10,0,10">

                    <!-- LOGO + PROJECT NAME -->
                    <StackPanel Margin="0,10,0,20" HorizontalAlignment="Center">
                        <Border Background="White"
                                CornerRadius="40"
                                Padding="8" Height="97" Width="140">
                            <Image Height="72"
                                   Width="72"
                                   Source="/logo_UR_blue.jpg"
                                   Stretch="Fill"/>
                        </Border>

                        <TextBlock Text="Student Management System"
                                   Foreground="White"
                                   FontSize="16"
                                   FontWeight="Bold"
                                   HorizontalAlignment="Center"
                                   Margin="0,12,0,0"/>

                        <TextBlock Text="Uniwersytet Rzeszowski"
                                   Foreground="#FFD9E6FF"
                                   FontSize="12"
                                   HorizontalAlignment="Center"/>
                    </StackPanel>

                    <!-- STUDENT SECTION -->
                    <Expander Header="Student"
                              Style="{StaticResource MenuExpanderStyle}"
                              IsExpanded="True">

                        <StackPanel>
                            <Button x:Name="registerStudentBtn"
                                    Content="Rejestracja"
                                    Style="{StaticResource SubMenuButtonStyle}"/>

                            <Button x:Name="manageStudentsBtn"
                                    Content="Zarządzanie studentami"
                                    Style="{StaticResource SubMenuButtonStyle}"/>

                            <Button x:Name="printStudentsBtn"
                                    Content="Drukuj"
                                    Style="{StaticResource SubMenuButtonStyle}"/>
                        </StackPanel>
                    </Expander>

                    <!-- OTHER SECTIONS -->
                    <Expander Header="Kursy"
                              Style="{StaticResource MenuExpanderStyle}">
                        <StackPanel>
                            <Button Content="Lista kursów"
                                    Style="{StaticResource SubMenuButtonStyle}"/>
                            <Button Content="Dodaj kurs"
                                    Style="{StaticResource SubMenuButtonStyle}"/>
                        </StackPanel>
                    </Expander>

                    <Expander Header="Wyniki"
                              Style="{StaticResource MenuExpanderStyle}">
                        <StackPanel>
                            <Button Content="Wprowadź wynik"
                                    Style="{StaticResource SubMenuButtonStyle}"/>
                            <Button Content="Przegląd wyników"
                                    Style="{StaticResource SubMenuButtonStyle}"/>
                        </StackPanel>
                    </Expander>

                    <Expander Header="Dashboard"
                              Style="{StaticResource MenuExpanderStyle}">
                        <StackPanel>
                            <Button Content="Statystyki"
                                    Style="{StaticResource SubMenuButtonStyle}"/>
                        </StackPanel>
                    </Expander>

                    <!-- EXIT BUTTON -->
                    <Button x:Name="exitBtn"
                            Content="Wyjście"
                            Margin="10,25,10,10"
                            Background="#FF002B66"
                            Foreground="White"
                            Height="40"
                            FontSize="16"
                            FontWeight="Bold"/>

                </StackPanel>
            </ScrollViewer>
        </Border>

        <!-- RIGHT SIDE -->
        <Grid Grid.Column="2" Margin="15,15,15,15">

            <!-- THREE ROWS -->
            <Grid.RowDefinitions>
                <RowDefinition Height="150"/>
                <RowDefinition Height="*"/>
                <RowDefinition Height="160"/>
            </Grid.RowDefinitions>

            <!-- TOP PANEL -->
            <Border Grid.Row="0"
                    Background="White"
                    CornerRadius="18"
                    Padding="22">

                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="120"/>
                    </Grid.ColumnDefinitions>

                    <StackPanel VerticalAlignment="Center">
                        <TextBlock Text="Uniwersytet Rzeszowski"
                                   FontSize="30"
                                   FontWeight="Bold"
                                   Foreground="#FF0047A1"/>

                        <StackPanel Orientation="Horizontal" Margin="0,14,0,0">
                            <TextBlock Text="Witaj:"
                                       FontSize="18"
                                       FontWeight="SemiBold"
                                       Foreground="#FF1F2D3D"/>
                            <TextBlock x:Name="welcomeUserText"
                                       Text="Administrator"
                                       FontSize="18"
                                       Foreground="#FF1F2D3D"
                                       Margin="8,0,0,0"/>
                        </StackPanel>

                        <StackPanel Orientation="Horizontal" Margin="0,6,0,0">
                            <TextBlock Text="Rola:"
                                       FontSize="18"
                                       FontWeight="SemiBold"
                                       Foreground="#FF1F2D3D"/>
                            <TextBlock x:Name="roleText"
                                       Text="Administrator systemu"
                                       FontSize="18"
                                       Foreground="#FF1F2D3D"
                                       Margin="8,0,0,0"/>
                        </StackPanel>
                    </StackPanel>

                    <!-- USER ICON -->
                    <Border Grid.Column="1"
                            Width="100"
                            Height="100"
                            Background="#FFEAF1FB"
                            CornerRadius="50"
                            HorizontalAlignment="Right"
                            VerticalAlignment="Center">
                        <TextBlock Text="👤"
                                   FontSize="46"
                                   HorizontalAlignment="Center"
                                   VerticalAlignment="Center"/>
                    </Border>

                </Grid>
            </Border>

            <!-- MIDDLE PANEL -->
            <Border Grid.Row="1"
                    Background="White"
                    CornerRadius="18"
                    Padding="15"
                    Margin="0,0,0,12">

                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="45"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>

                    <TextBlock x:Name="sectionTitleText"
                               Text="Panel główny"
                               FontSize="22"
                               FontWeight="Bold"
                               Foreground="#FF0047A1"
                               VerticalAlignment="Center"/>

                    <Border Grid.Row="1"
                            Background="#FFF7F9FC"
                            CornerRadius="12"
                            BorderBrush="#FFD8E1F0"
                            BorderThickness="1"
                            Padding="10">

                        <Grid x:Name="contentArea"/>
                    </Border>
                </Grid>
            </Border>

            <!-- BOTTOM PANEL -->
            <Border Grid.Row="2"
                    Background="#FF0047A1"
                    CornerRadius="18"
                    Padding="22">

                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>

                    <!-- LEFT -->
                    <StackPanel VerticalAlignment="Center">
                        <TextBlock Text="Liczba studentów"
                                   FontSize="18"
                                   Foreground="White"
                                   FontWeight="Bold"/>

                        <StackPanel Orientation="Horizontal" Margin="0,12,0,0">
                            <TextBlock Text="Mężczyźni:"
                                       Foreground="White"
                                       FontSize="16"/>
                            <TextBlock x:Name="maleCountText"
                                       Text="0"
                                       Foreground="White"
                                       FontSize="16"
                                       FontWeight="SemiBold"
                                       Margin="8,0,24,0"/>

                            <TextBlock Text="Kobiety:"
                                       Foreground="White"
                                       FontSize="16"/>
                            <TextBlock x:Name="femaleCountText"
                                       Text="0"
                                       Foreground="White"
                                       FontSize="16"
                                       FontWeight="SemiBold"
                                       Margin="8,0,0,0"/>
                        </StackPanel>
                    </StackPanel>

                    <!-- CENTER -->
                    <StackPanel Grid.Column="1"
                                VerticalAlignment="Center"
                                Margin="25,0,25,0">

                        <TextBlock Text="Wybierz grupę"
                                   Foreground="White"
                                   FontSize="18"
                                   FontWeight="Bold"
                                   Margin="0,0,0,10"/>

                        <ComboBox x:Name="classComboBox"
                                  Height="34"
                                  FontSize="15"
                                  SelectedIndex="0">
                            <ComboBoxItem Content="Grupa A"/>
                            <ComboBoxItem Content="Grupa B"/>
                            <ComboBoxItem Content="Grupa C"/>
                            <ComboBoxItem Content="Grupa D"/>
                        </ComboBox>
                    </StackPanel>

                    <!-- RIGHT -->
                    <StackPanel Grid.Column="2"
                                VerticalAlignment="Center"
                                HorizontalAlignment="Right">

                        <TextBlock Text="Statystyki"
                                   FontSize="18"
                                   Foreground="White"
                                   FontWeight="Bold"
                                   HorizontalAlignment="Right"/>

                        <StackPanel Orientation="Horizontal" Margin="0,12,0,0">
                            <TextBlock Text="Mężczyźni:"
                                       Foreground="White"
                                       FontSize="16"/>
                            <TextBlock Text="0"
                                       Foreground="White"
                                       FontSize="16"
                                       FontWeight="SemiBold"
                                       Margin="8,0,20,0"/>

                            <TextBlock Text="Kobiety:"
                                       Foreground="White"
                                       FontSize="16"/>
                            <TextBlock Text="0"
                                       Foreground="White"
                                       FontSize="16"
                                       FontWeight="SemiBold"
                                       Margin="8,0,0,0"/>
                        </StackPanel>
                    </StackPanel>

                </Grid>
            </Border>

        </Grid>
    </Grid>
</Window>
