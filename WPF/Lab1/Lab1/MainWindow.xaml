<Window x:Class="Lab1.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:Lab1"
        mc:Ignorable="d"
        Title="Login SMS" Height="450" Width="800">


    <Grid>
        <TextBlock x:Name="TitleText"
                   HorizontalAlignment="Left"
                   Margin="114,34,0,0"
                   TextWrapping="Wrap"
                   Text="Uniwersytet Rzeszowski"
                   VerticalAlignment="Top"
                   FontWeight="Bold"
                   FontSize="24"/>

        <TextBlock x:Name="LoginLabel"
                   HorizontalAlignment="Left"
                   Margin="308,136,0,0"
                   TextWrapping="Wrap"
                   Text="Login:"
                   VerticalAlignment="Top"
                   FontWeight="Bold"
                   FontSize="18"/>

        <TextBox x:Name="LoginBox"
                 HorizontalAlignment="Center"
                 Margin="0,168,0,0"
                 Width="184"
                 Height="19"
                 VerticalAlignment="Top"/>

        <TextBlock x:Name="PasswordLabel"
                   HorizontalAlignment="Left"
                   Margin="308,202,0,0"
                   TextWrapping="Wrap"
                   VerticalAlignment="Top"
                   FontWeight="Bold"
                   FontSize="18"><Run Text="Hasło"/><Run Text=":"/></TextBlock>

        <Button Content="Zaloguj"
                HorizontalAlignment="Center"
                Margin="0,286,0,0"
                VerticalAlignment="Top"
                Width="184"
                Height="25"
                Background="#FF0659F2"
                Foreground="White"
                FontWeight="Bold" Click="Button_Click"/>
        <Image HorizontalAlignment="Left" Height="69" Margin="31,10,0,0" VerticalAlignment="Top" Width="69" Source="/logo_UR_blue.jpg"/>
        <PasswordBox x:Name="PasswordBox" HorizontalAlignment="Center" Margin="0,231,0,0" VerticalAlignment="Top" Width="184" Height="19"/>
    </Grid>
</Window>


